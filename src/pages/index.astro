---
import Layout from '../layouts/Layout.astro';

const marqueeImages = [
  'attention-to-detail.webp',
  'mid-build-beautiful-day.webp',
  'owner-lifting-beam.webp',
  'truss-day.webp',
  'attention-to-detail-2.webp',
  'framed-with-windows.webp',
  'worker-at-sawhorse.webp',
  'attention-to-detail-3.webp',
  'build-under-progress.webp',
  'inside-gazebo.webp'
];
---

<Layout
  title="Two Seven Builders. Luxury Custom Home Design-Build · Ottawa Valley"
  description="Two Seven Builders is a design-build firm crafting high-performance luxury custom homes across the Ottawa Valley. Ottawa, Renfrew County, Lanark Highlands, Calabogie, Pembroke and Madawaska Valley. Built once. Built to be kept."
  intro={true}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" style="background-image:url('/images/luxury-shop.webp')"></div>
    <div class="hero-overlay"></div>

    <span class="hero-tag">Est. Ottawa Valley</span>

    <div class="hero-headline-wrap">
      <h1 class="hero-headline serif">Designed by Us. Built by Us. <em>Made for You.</em></h1>
      <p class="hero-sub">Custom carpentry and in-house design team for homeowners who want it done right the first time.</p>
      <a href="/contact" class="btn">Start the Process <span class="arrow">→</span></a>
    </div>

    <div class="hero-scroll">Scroll</div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto">
    <div class="wrap-narrow">
      <span class="eyebrow fade-up">Two Seven Builders</span>
      <h2 class="serif split-text">A small builder for clients who want the bones right and the finish quiet.</h2>
      <p class="muted fade-up d-2">In-house design. Custom carpentry. High-performance construction. Run by the people who do the work, for clients who care less about square footage and more about whether the floor is still flat in fifty years.</p>
    </div>
  </section>

  <!-- PHASES — each panel paired with its own visible photo -->
  <section class="phases-rows">
    <article class="phase-row">
      <div class="phase-img clip-up"><img src="/images/foundation-pre-build.webp" alt="Foundation, pre-build, drainage detailed for Valley clay" data-parallax="0.08" /></div>
      <div class="phase-text fade-right">
        <span class="eyebrow">01 Below Grade</span>
        <h3 class="serif split-text">Where every quiet house begins.</h3>
        <p class="muted">
          Drainage, waterproofing, footing depth. All decided long before anyone notices the kitchen. The Valley's clay and freeze-thaw demand more than the code minimum, so we give it more.
        </p>
      </div>
    </article>

    <article class="phase-row phase-row-rev">
      <div class="phase-img clip-up"><img src="/images/mid-build-beautiful-day.webp" alt="Mid build under a clear summer sky" data-parallax="0.10" /></div>
      <div class="phase-text fade-left">
        <span class="eyebrow">02 Above Grade</span>
        <h3 class="serif split-text">The bones, set true.</h3>
        <p class="muted">
          Engineered floors. Sealed sub-floors. Trusses raised on a clear morning by people who've raised a thousand. Every fastener placed on a schedule, every plate checked, every line snapped twice.
        </p>
      </div>
    </article>

    <article class="phase-row">
      <div class="phase-img clip-up"><img src="/images/finished-house-night-drop.webp" alt="Finished custom home at dusk" data-parallax="0.08" /></div>
      <div class="phase-text fade-right">
        <span class="eyebrow">03 Move In</span>
        <h3 class="serif split-text">A home that performs as well as it looks.</h3>
        <p class="muted">
          Lights on. Quiet. Warm. The work disappears into the walls, exactly as it should. We hand over a house that will outlast everyone who built it.
        </p>
      </div>
    </article>
  </section>

  <!-- FEATURE ROWS — alternating image / text with parallax -->
  <section class="feature-rows">
    <article class="feature-row">
      <div class="feature-row-img clip-up">
        <img src="/images/owner-lifting-beam.webp" alt="On the floor, lifting a beam" data-parallax="0.10" />
      </div>
      <div class="feature-row-text fade-right reveal-stagger">
        <span class="eyebrow">01 Site</span>
        <h3 class="serif split-text">We walk the land before we draw.</h3>
        <p>Slope, sun, wind, water, neighbouring rooflines. Every parcel speaks first, and the architecture follows. The result is a home that feels inevitable, not imposed.</p>
      </div>
    </article>

    <article class="feature-row feature-row-rev">
      <div class="feature-row-img clip-up">
        <img src="/images/framed-with-windows.webp" alt="Framed home with new windows" data-parallax="0.08" />
      </div>
      <div class="feature-row-text fade-left reveal-stagger">
        <span class="eyebrow">02 Design</span>
        <h3 class="serif split-text">Drawings precise enough to build from.</h3>
        <p>Wall sections, flashing details, mechanical coordination, structural sign off. Every page vetted before tender. Vague drawings produce vague buildings. Ours don't leave room for guessing on site.</p>
      </div>
    </article>

    <article class="feature-row">
      <div class="feature-row-img clip-up">
        <img src="/images/truss-day.webp" alt="Trusses raised on a clear morning" data-parallax="0.10" />
      </div>
      <div class="feature-row-text fade-right reveal-stagger">
        <span class="eyebrow">03 Build</span>
        <h3 class="serif split-text">The same crew, every day.</h3>
        <p>No revolving door of subs. Our trades are people we've worked with for a decade, answering to one foreman from the foundation pour to the final walkthrough.</p>
      </div>
    </article>

    <article class="feature-row feature-row-rev">
      <div class="feature-row-img clip-up">
        <img src="/images/attention-to-detail.webp" alt="Hand finished joinery detail" data-parallax="0.08" />
      </div>
      <div class="feature-row-text fade-left reveal-stagger">
        <span class="eyebrow">04 Finish</span>
        <h3 class="serif split-text">The details are where the house is.</h3>
        <p>Trim that meets without caulk lines. Cabinetry that closes flush in a heat wave. Hardware that stays tight forty years on. We specify materials we'd live with, and we'll tell you when a beautiful idea will look tired in a decade.</p>
      </div>
    </article>
  </section>

  <!-- BIG QUOTE — full-bleed image with dark overlay -->
  <section class="big-quote">
    <div class="bq-bg" style="background-image:url('/images/finished-house-night-drop.webp')" data-parallax="0.18"></div>
    <div class="wrap">
      <span class="eyebrow fade-up" style="color:var(--bone); opacity:0.8;">No squeaks. No callbacks.</span>
      <h2 class="serif fade-up d-1">A house that performs as well as it looks. <em>Built to be kept.</em></h2>
    </div>
  </section>

  <!-- IMAGE MARQUEE — auto-scrolling photo strip -->
  <section class="marquee" aria-label="Recent work">
    <div class="marquee-track">
      {marqueeImages.map((img) => (
        <figure class="marquee-item">
          <img src={`/images/${img}`} alt="Two Seven Builders site work" />
        </figure>
      ))}
      {marqueeImages.map((img) => (
        <figure class="marquee-item" aria-hidden="true">
          <img src={`/images/${img}`} alt="" />
        </figure>
      ))}
    </div>
  </section>

  <!-- TRIPTYCH — Design / Build / About cards -->
  <section class="triptych-section">
    <div class="wrap" style="margin-bottom: clamp(40px, 5vw, 72px);">
      <div class="fade-up" style="display:flex; justify-content:space-between; align-items:end; gap:32px; flex-wrap:wrap;">
        <div>
          <span class="eyebrow">Where to next</span>
          <h2 class="serif split-text" style="margin-top:14px; max-width:18ch;">Three doors. One studio.</h2>
        </div>
        <p class="muted" style="max-width:42ch;">From the first site walk to the last punch list item, the same people are in the room. Walk through what each door looks like.</p>
      </div>
    </div>

    <div class="triptych">
      <a class="tri-card fade-up" href="/design">
        <div class="tri-img" style="background-image:url('/images/efficient-home.webp')"></div>
        <div class="tri-overlay"></div>
        <div class="tri-content">
          <span class="num">01</span>
          <h3 class="serif">Design</h3>
          <p>Listen first. Draw second. Every line on paper has been on the land.</p>
          <span class="tri-cta">Explore <span class="arrow">→</span></span>
        </div>
      </a>

      <a class="tri-card fade-up d-1" href="/build">
        <div class="tri-img" style="background-image:url('/images/mid-build-beautiful-day.webp')"></div>
        <div class="tri-overlay"></div>
        <div class="tri-content">
          <span class="num">02</span>
          <h3 class="serif">Build</h3>
          <p>Built once. Built to be kept. No squeaks, no callbacks, no compromises.</p>
          <span class="tri-cta">Explore <span class="arrow">→</span></span>
        </div>
      </a>

      <a class="tri-card fade-up d-2" href="/about">
        <div class="tri-img" style="background-image:url('/images/worker-at-sawhorse.webp')"></div>
        <div class="tri-overlay"></div>
        <div class="tri-content">
          <span class="num">03</span>
          <h3 class="serif">About</h3>
          <p>A small team and a long memory. The people who quote the work do the work.</p>
          <span class="tri-cta">Explore <span class="arrow">→</span></span>
        </div>
      </a>
    </div>
  </section>

  <!-- DETAIL GALLERY — quiet close ups, parallax grid -->
  <section class="detail-gallery">
    <div class="wrap" style="margin-bottom: clamp(36px, 4vw, 56px);">
      <div class="fade-up">
        <span class="eyebrow">In the seams</span>
        <h2 class="serif split-text" style="margin-top:14px;">The work nobody photographs.</h2>
      </div>
    </div>
    <div class="dg-grid">
      <figure class="dg-tile clip-up">
        <img src="/images/attention-to-detail-2.webp" alt="Close up of finish carpentry" data-parallax="0.06" />
      </figure>
      <figure class="dg-tile clip-up d-1">
        <img src="/images/attention-to-detail-3.webp" alt="Material selection and detail" data-parallax="0.08" />
      </figure>
      <figure class="dg-tile clip-up d-2">
        <img src="/images/clean-site-inside-house.webp" alt="Clean job site inside a framed house" data-parallax="0.05" />
      </figure>
      <figure class="dg-tile clip-up d-3">
        <img src="/images/inside-gazebo.webp" alt="Pavilion interior, finished" data-parallax="0.07" />
      </figure>
      <figure class="dg-tile clip-up d-4">
        <img src="/images/build-under-progress.webp" alt="Mid build, framing stage" data-parallax="0.06" />
      </figure>
      <figure class="dg-tile clip-up d-5">
        <img src="/images/shop-in-fall.webp" alt="The shop in fall" data-parallax="0.08" />
      </figure>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="wrap-narrow" style="text-align:center;">
      <span class="eyebrow fade-up">Begin</span>
      <h2 class="serif split-text">Ready to build?</h2>
      <p class="fade-up d-2">We take a limited number of projects each year. Custom homes across Ottawa, Renfrew County, Lanark Highlands, Calabogie, and the Madawaska Valley. Start the conversation.</p>
      <a href="/contact" class="btn fade-up d-3">Start the Process <span class="arrow">→</span></a>
    </div>
  </section>
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero { position: relative; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.50) 0%, rgba(0,0,0,0.22) 38%, rgba(0,0,0,0) 68%),
      linear-gradient(180deg, rgba(0,0,0,0.12) 0%, rgba(0,0,0,0) 35%, rgba(0,0,0,0.32) 100%);
  }
  .hero-tag, .hero-scroll { z-index: 4; }
  .hero-headline-wrap {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    text-align: left;
    padding: 0 clamp(28px, 6vw, 96px);
    gap: clamp(16px, 1.6vw, 26px);
  }
  .hero-headline {
    font-size: clamp(36px, 5.4vw, 88px);
    line-height: 1.02;
    letter-spacing: -0.018em;
    color: var(--bone);
    max-width: 18ch;
    font-weight: 300;
    margin: 0;
    text-shadow: 0 2px 28px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.40);
  }
  .hero-headline em { font-style: italic; }
  .hero-sub {
    font-family: var(--sans);
    font-size: clamp(14px, 1.15vw, 18px);
    line-height: 1.55;
    font-weight: 300;
    color: var(--bone);
    opacity: 0.92;
    max-width: 52ch;
    margin: 0;
    text-shadow: 0 1px 18px rgba(0,0,0,0.55), 0 1px 2px rgba(0,0,0,0.4);
  }

  /* ---------- Manifesto ---------- */
  .manifesto {
    padding: clamp(120px, 16vw, 220px) var(--gut);
    text-align: center;
    border-bottom: 1px solid var(--rule);
  }
  .manifesto .eyebrow {
    display: inline-block;
    margin-bottom: clamp(28px, 3vw, 44px);
  }
  .manifesto h2 {
    font-size: clamp(32px, 4.6vw, 76px);
    max-width: 22ch;
    margin: 0 auto clamp(28px, 3vw, 44px);
    line-height: 1.1;
  }
  .manifesto p {
    max-width: 56ch;
    margin: 0 auto;
    font-size: clamp(15px, 1.15vw, 19px);
    line-height: 1.7;
  }

  /* ---------- Phases rows (each panel has its own visible photo) ---------- */
  .phases-rows {
    padding: clamp(80px, 12vw, 160px) 0;
    display: flex;
    flex-direction: column;
    gap: clamp(80px, 12vw, 160px);
    border-bottom: 1px solid var(--rule);
  }
  .phase-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(40px, 8vw, 120px);
    padding: 0 clamp(28px, 6vw, 96px);
  }
  .phase-row-rev .phase-img { order: 2; }
  .phase-row-rev .phase-text { order: 1; }
  .phase-img {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--grey-1);
  }
  .phase-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s var(--ease), filter 1s var(--ease);
    filter: brightness(0.95);
  }
  .phase-row:hover .phase-img img { transform: scale(1.04); filter: brightness(1); }
  .phase-text { padding: clamp(20px, 3vw, 40px) 0; }
  .phase-text .eyebrow { margin-bottom: 18px; display: inline-block; }
  .phase-text h3 {
    font-size: clamp(30px, 3.6vw, 56px);
    max-width: 16ch;
    margin-bottom: 24px;
    line-height: 1.06;
  }
  .phase-text p {
    max-width: 46ch;
    font-size: clamp(15px, 1.05vw, 18px);
    line-height: 1.7;
  }
  @media (max-width: 900px) {
    .phase-row,
    .phase-row-rev {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .phase-row-rev .phase-img { order: 0; }
    .phase-row-rev .phase-text { order: 1; }
    .phase-img { aspect-ratio: 4 / 3; }
  }

  /* ---------- Feature rows (alternating image/text) ---------- */
  .feature-rows {
    padding: clamp(100px, 14vw, 200px) 0;
    display: flex;
    flex-direction: column;
    gap: clamp(80px, 12vw, 180px);
  }
  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(40px, 8vw, 120px);
    padding: 0 clamp(28px, 6vw, 96px);
  }
  .feature-row-rev .feature-row-img { order: 2; }
  .feature-row-rev .feature-row-text { order: 1; }
  .feature-row-img {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--grey-1);
  }
  .feature-row-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s var(--ease), filter 1s var(--ease);
    filter: brightness(0.92);
  }
  .feature-row:hover .feature-row-img img { transform: scale(1.04); filter: brightness(1); }
  .feature-row-text { padding: clamp(20px, 3vw, 40px) 0; }
  .feature-row-text .eyebrow { margin-bottom: 18px; display: inline-block; }
  .feature-row-text h3 {
    font-size: clamp(30px, 3.6vw, 56px);
    max-width: 16ch;
    margin-bottom: 24px;
    line-height: 1.06;
  }
  .feature-row-text p {
    max-width: 48ch;
    font-size: clamp(15px, 1.05vw, 18px);
    line-height: 1.7;
    color: var(--grey-4);
  }
  @media (max-width: 900px) {
    .feature-row,
    .feature-row-rev {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .feature-row-rev .feature-row-img { order: 0; }
    .feature-row-rev .feature-row-text { order: 1; }
    .feature-row-img { aspect-ratio: 4 / 3; }
  }

  /* ---------- Big quote (full bleed) ---------- */
  .big-quote {
    position: relative;
    padding: clamp(140px, 18vw, 260px) 0;
    overflow: hidden;
    isolation: isolate;
  }
  .big-quote .bq-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: -1;
    transform: scale(1.04);
    will-change: transform;
  }
  .big-quote .bq-bg::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.55) 50%, rgba(0,0,0,0.65) 100%);
  }
  .big-quote .wrap { text-align: center; position: relative; }
  .big-quote h2 {
    font-size: clamp(34px, 5vw, 84px);
    max-width: 22ch;
    margin: 14px auto 0;
    color: var(--bone);
    line-height: 1.15;
    text-shadow: 0 2px 30px rgba(0,0,0,0.45);
  }
  .big-quote h2 em { font-style: italic; }

  /* ---------- Image marquee (auto-scrolling) ---------- */
  .marquee {
    overflow: hidden;
    padding: clamp(60px, 8vw, 120px) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--grey-1);
  }
  .marquee-track {
    display: flex;
    gap: clamp(16px, 1.6vw, 28px);
    width: max-content;
    animation: marquee-scroll 80s linear infinite;
  }
  .marquee-track:hover { animation-play-state: paused; }
  .marquee-item {
    flex: 0 0 auto;
    margin: 0;
  }
  .marquee-item img {
    width: clamp(280px, 26vw, 440px);
    height: clamp(220px, 18vw, 320px);
    object-fit: cover;
    display: block;
    filter: grayscale(0.1) brightness(0.95);
    transition: filter 0.6s var(--ease);
  }
  .marquee-item:hover img { filter: grayscale(0) brightness(1); }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  /* ---------- Triptych (Design / Build / About) ---------- */
  .triptych-section {
    padding: clamp(100px, 12vw, 160px) 0;
  }
  .triptych {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    padding: 0;
  }
  .tri-card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--black);
    color: var(--bone);
    text-decoration: none;
  }
  .tri-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: grayscale(0.15) brightness(0.7);
    transform: scale(1.04);
    transition: transform 1.4s var(--ease), filter 1s var(--ease);
  }
  .tri-card:hover .tri-img {
    transform: scale(1.10);
    filter: grayscale(0) brightness(0.85);
  }
  .tri-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.10) 0%, rgba(0,0,0,0.35) 55%, rgba(0,0,0,0.78) 100%);
  }
  .tri-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(28px, 3.5vw, 56px);
    z-index: 2;
  }
  .tri-content .num {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    opacity: 0.75;
    margin-bottom: 12px;
  }
  .tri-content h3 {
    font-size: clamp(36px, 4vw, 64px);
    margin: 0 0 12px;
    line-height: 1;
  }
  .tri-content p {
    max-width: 30ch;
    font-size: clamp(14px, 1vw, 16px);
    line-height: 1.55;
    opacity: 0.9;
    margin-bottom: 22px;
  }
  .tri-cta {
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 4px;
    align-self: flex-start;
    transition: gap 0.4s var(--ease);
  }
  .tri-cta .arrow {
    display: inline-block;
    margin-left: 10px;
    transition: transform 0.4s var(--ease);
  }
  .tri-card:hover .tri-cta .arrow { transform: translateX(6px); }
  @media (max-width: 900px) {
    .triptych { grid-template-columns: 1fr; }
    .tri-card { aspect-ratio: 16 / 11; }
  }

  /* ---------- Detail gallery ---------- */
  .detail-gallery {
    padding: clamp(100px, 12vw, 160px) 0;
    background: var(--bone);
    color: var(--black);
  }
  .detail-gallery .wrap .eyebrow { color: var(--grey-3); }
  .detail-gallery .wrap h2 { color: var(--black); }
  .dg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(12px, 1.4vw, 22px);
    padding: 0 clamp(24px, 4vw, 56px);
  }
  .dg-tile {
    position: relative;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--grey-2);
  }
  .dg-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s var(--ease), filter 1s var(--ease);
    filter: brightness(0.95);
  }
  .dg-tile:hover img { transform: scale(1.05); filter: brightness(1); }
  @media (max-width: 900px) {
    .dg-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .dg-grid { grid-template-columns: 1fr; }
  }

  /* ---------- CTA ---------- */
  .cta-section {
    padding: clamp(100px, 14vw, 200px) var(--gut);
