---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  active?: string;
  /** When true, plays the page-load intro overlay (homepage only). */
  intro?: boolean;
}

const {
  title = 'Two Seven Builders. Custom Homes in the Ottawa Valley',
  description = 'Two Seven Builders is a design-build firm for high-performance luxury custom homes across the Ottawa Valley. Serving Ottawa, Renfrew County, Lanark Highlands, Calabogie, Pembroke and Madawaska Valley.',
  active = '',
  intro = false
} = Astro.props;

const links = [
  { href: '/about', label: 'About', key: 'about' },
  { href: '/design', label: 'Design', key: 'design' },
  { href: '/build', label: 'Build', key: 'build' },
  { href: '/contact', label: 'Contact', key: 'contact' }
];

const locations = [
  'Ottawa',
  'Kanata',
  'Carleton Place',
  'Almonte',
  'Arnprior',
  'Renfrew',
  'Calabogie',
  'Eganville',
  'Pembroke',
  "Barry's Bay",
  'Madawaska Valley',
  'Lanark Highlands'
];
---

<!doctype html>
<html lang="en" class={intro ? 'has-intro' : ''}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,200;0,300;0,400;0,500;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="preload" as="image" href="/images/logo.png" />
    <script is:inline>
      // Skip the homepage intro on internal navigation. It still plays on hard
      // refresh (URL refresh), direct visits (bookmarks, external links), and
      // first-time loads. only same-origin nav from another page bypasses it.
      (function () {
        var html = document.documentElement;
        if (!html.classList.contains('has-intro')) return;
        try {
          var nav = (performance.getEntriesByType && performance.getEntriesByType('navigation')[0]) || null;
          var navType = (nav && nav.type) || '';
          var ref = document.referrer || '';
          var sameOrigin = false;
          if (ref) {
            try { sameOrigin = new URL(ref).origin === window.location.origin; } catch (e) {}
          }
          if (sameOrigin && navType !== 'reload') {
            html.classList.add('intro-skip', 'intro-loaded', 'intro-finishing', 'intro-done', 'intro-finished');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={intro ? 'intro-active' : ''}>
    {intro && (
      <div class="intro" aria-hidden="true">
        <div class="intro-brand">
          <img src="/images/logo.png" alt="" class="intro-logo-big" />
          <span class="intro-kicker-big">
            <a href="/design" class="ik-word ik-left">Design</a>
            <span class="intro-kicker-sep">+</span>
            <a href="/build" class="ik-word ik-right">Build</a>
          </span>
        </div>
      </div>
    )}

    <!-- Scroll progress bar -->
    <div class="scroll-progress"><span></span></div>

    <header class="nav">
      <a class="nav-logo" href="/" aria-label="Two Seven Builders">
        <img src="/images/logo.png" alt="Two Seven Builders" class="nav-logo-img" />
      </a>
      <nav class="nav-links" aria-label="Primary">
        {links.map((l) => (<a href={l.href} class={active === l.key ? 'is-active' : ''}>{l.label}</a>))}
      </nav>
      <button class="nav-menu" aria-label="Open menu">
        <span class="nav-menu-label">Menu</span>
        <span class="nav-menu-icon"><span></span><span></span></span>
      </button>
    </header>

    <!-- Small location + clock pin, bottom-left of viewport -->
    <aside class="meta-pin" aria-hidden="true">
      <span><span class="dot"></span>Ottawa Valley, ON</span>
      <span id="navClock">.  EST</span>
    </aside>

    <div class="nav-overlay">
      <button class="nav-overlay-close" aria-label="Close menu" type="button">
        <span class="nav-overlay-close-label">Close</span>
        <span class="nav-overlay-close-icon" aria-hidden="true"><span></span><span></span></span>
      </button>
      <div class="nav-overlay-links">
        {links.map((l) => (<a href={l.href}>{l.label}</a>))}
      </div>
      <div class="nav-overlay-meta">
        <span>Ottawa Valley, ON</span>
        <span>info@twosevenbuilders.ca</span>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-top">
        <div>
          <img src="/images/logo.png" alt="Two Seven Builders" class="footer-logo-img" />
          <p class="muted" style="margin-top:32px; max-width:32ch;">
            Custom homes, start to finish. Valley-trained, building from Ottawa to the Madawaska.
          </p>
        </div>
        <div class="footer-col">
          <h5>Site</h5>
          <ul>
            {links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>
        <div class="footer-col">
          <h5>Contact</h5>
          <ul>
            <li>(613) 555-0127</li>
            <li><a href="mailto:info@twosevenbuilders.ca">info@twosevenbuilders.ca</a></li>
            <li>Ottawa Valley, ON</li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Studio</h5>
          <ul>
            <li>27 Riverside Lane</li>
            <li>Renfrew County, ON</li>
            <li>K7V 0A0</li>
          </ul>
        </div>
        <div class="footer-col footer-col-locations" aria-label="Service area">
          <h5>Service area</h5>
          <ul>
            {locations.map((city) => (<li>{city}</li>))}
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© Two Seven Builders 2025</span>
        <div class="socials">
          <a href="#">Instagram</a>
          <a href="#">Houzz</a>
          <a href="#">LinkedIn</a>
        </div>
        <span>Site v1.0</span>
      </div>
    </footer>

    <style is:global>
      /* ---------- Intro overlay (homepage only) ---------- */
      html.has-intro,
      html.has-intro body { overflow: hidden; }
      html.has-intro.intro-done,
      html.has-intro.intro-done body { overflow: visible; overflow-x: hidden; }

      /* When arriving via internal navigation, the intro is bypassed entirely:
         hide the overlay node, render the hero in its final state with no transitions. */
      html.intro-skip .intro { display: none !important; }
      html.intro-skip .nav,
      html.intro-skip .hero-headline-wrap > *,
      html.intro-skip .hero-logo-top,
      html.intro-skip .hero-scroll,
      html.intro-skip .hero-tag,
      html.intro-skip .meta-pin,
      html.intro-skip .scroll-progress {
        transition: none !important;
      }

      .intro {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: var(--black);
        overflow: hidden;
        /* Soft vignette draws the eye to the center stage */
        transition:
          opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
          visibility 0s linear 0.7s;
      }
      .intro::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 50% 50%, rgba(255,255,255,0.04) 0%, rgba(0,0,0,0) 55%);
        pointer-events: none;
      }
      html.intro-done .intro {
        opacity: 0;
        visibility: hidden;
      }
      .intro-brand {
        position: absolute;
        left: 50%;
        top: 50%;
        /* Hidden start: slightly above and scaled down. enters with the video */
        transform: translate(-50%, -42%) scale(0.92);
        opacity: 0;
        z-index: 5;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(20px, 2.2vw, 36px);
        padding: 0 var(--gut);
        text-align: center;
        /* One unified curve + duration so logo, tagline and position all move as a single gesture */
        transition:
          top 1.05s cubic-bezier(0.65, 0, 0.35, 1),
          left 1.05s cubic-bezier(0.65, 0, 0.35, 1),
          transform 1.05s cubic-bezier(0.65, 0, 0.35, 1),
          opacity 1.1s cubic-bezier(0.4, 0, 0.2, 1),
          align-items 0s linear 1.05s;
      }
      /* Phase 1: entrance. logo + tagline rise into place with the video's motion */
      html.intro-loaded .intro-brand {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      .intro-logo-big {
        display: block;
        width: clamp(280px, 38vw, 520px);
        height: auto;
        filter: brightness(0) invert(1) drop-shadow(0 0 50px rgba(242, 237, 230, 0.12));
        transform: scale(1);
        transition:
          transform 1.2s cubic-bezier(0.32, 0, 0.67, 0),
          opacity 0.5s cubic-bezier(0.4, 0, 1, 1) 0.7s;
      }
      .intro-kicker-big {
        font-family: var(--sans);
        font-size: clamp(12px, 1.05vw, 15px);
        font-weight: 400;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        color: var(--bone);
        opacity: 0.88;
        display: inline-flex;
        gap: 0.5em;
      }
      .intro-kicker-big a,
      .intro-kicker-big .intro-kicker-sep {
        display: inline-block;
        transition:
          transform 0.95s cubic-bezier(0.65, 0, 0.35, 1),
          opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .intro-kicker-big a {
        color: inherit;
        text-decoration: none;
        position: relative;
        transition: opacity 0.3s var(--ease);
      }
      .intro-kicker-big a:hover { opacity: 0.7; }
      .intro-kicker-big a::after {
        content: '';
        position: absolute;
        left: 0; right: 0; bottom: -4px;
        height: 1px;
        background: currentColor;
        opacity: 0;
        transition: opacity 0.3s var(--ease);
      }
      .intro-kicker-big a:hover::after { opacity: 0.7; }
      .intro-kicker-big .intro-kicker-sep { opacity: 0.55; }
      /* Phase 2: SPLIT-ZOOM. words fly toward the logo and scale up while fading. */
      html.intro-finishing .intro-kicker-big a.ik-left,
      html.intro-finishing .intro-kicker-big a:first-of-type {
        transform: translate(0.7em, -2.2em) scale(1.55);
        opacity: 0;
        transition:
          transform 0.85s cubic-bezier(0.7, 0, 0.25, 1),
          opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.1s;
      }
      html.intro-finishing .intro-kicker-big a.ik-right,
      html.intro-finishing .intro-kicker-big a:last-of-type {
        transform: translate(-0.7em, -2.2em) scale(1.55);
        opacity: 0;
        transition:
          transform 0.85s cubic-bezier(0.7, 0, 0.25, 1),
          opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.1s;
      }
      html.intro-finishing .intro-kicker-big .intro-kicker-sep {
        transform: translateY(-2.2em) scale(0.3);
        opacity: 0;
        transition:
          transform 0.7s cubic-bezier(0.55, 0, 0.45, 1),
          opacity 0.45s ease;
      }
      /* Logo pulses larger as it absorbs the words */
      html.intro-finishing .intro-logo-big {
        transform: scale(1.12);
        transition: transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      /* Phase 3 (intro-done): logo expands further while overlay fades — handoff to hero */
      html.intro-done .intro-logo-big {
        transform: scale(1.9);
        opacity: 0;
        transition:
          transform 0.95s cubic-bezier(0.5, 0, 0.5, 1),
          opacity 0.55s ease 0.2s;
      }
      html.intro-done .intro {
        pointer-events: none;
      }
      /* legacy intro panels (unused with video intro, kept for safety) */
      .intro-half {
        position: absolute;
        left: 0; right: 0;
        height: 50%;
        background: var(--black);
        will-change: transform;
        transition: transform 1.4s cubic-bezier(0.76, 0, 0.24, 1);
      }
      .intro-top    { top: 0;    transform: translateY(0); }
      .intro-bottom { bottom: 0; transform: translateY(0); }

      .intro-logo-wrap {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: clamp(28px, 3vw, 48px);
        z-index: 2;
        padding: 0 var(--gut);
        text-align: center;
        transition: opacity 0.6s ease 0.2s, transform 1.2s cubic-bezier(0.76, 0, 0.24, 1);
      }
      .intro-kicker {
        font-family: var(--sans);
        font-size: 12px;
        letter-spacing: 0.36em;
        text-transform: uppercase;
        color: var(--bone);
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 0.9s ease 0.05s, transform 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.05s;
      }
      .intro-logo {
        width: clamp(220px, 32vw, 480px);
        height: auto;
        opacity: 0;
        transform: scale(0.94);
        transition: opacity 1.0s ease 0.25s, transform 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.25s;
        filter: drop-shadow(0 0 36px rgba(242, 237, 230, 0.06));
      }
      .intro-tagline {
        font-family: var(--serif);
        font-size: clamp(20px, 2.1vw, 32px);
        line-height: 1.25;
        letter-spacing: -0.018em;
        color: var(--bone);
        max-width: 26ch;
        font-weight: 300;
        opacity: 0;
        transform: translateY(14px);
        transition: opacity 1s ease 0.55s, transform 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.55s;
      }
      .intro-tagline em { font-style: italic; opacity: 0.88; }
      html.intro-loaded .intro-kicker,
      html.intro-loaded .intro-logo,
      html.intro-loaded .intro-tagline {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      html.intro-done .intro-top    { transform: translateY(-100%); }
      html.intro-done .intro-bottom { transform: translateY(100%); }
      html.intro-done .intro-logo-wrap { opacity: 0; transform: scale(1.04); }
      html.intro-done .intro { pointer-events: none; }

      /* Hero chrome stays hidden during intro, fades in once intro completes */
      html.has-intro:not(.intro-done) .hero-logo-top,
      html.has-intro:not(.intro-done) .hero-scroll,
      html.has-intro:not(.intro-done) .hero-tag,
      html.has-intro:not(.intro-done) .nav,
      html.has-intro:not(.intro-done) .meta-pin,
      html.has-intro:not(.intro-done) .scroll-progress {
        opacity: 0;
      }
      html.has-intro .hero-logo-top,
      html.has-intro .hero-tag,
      html.has-intro .meta-pin,
      html.has-intro .scroll-progress {
        transition: opacity 0.9s cubic-bezier(0.4, 0, 0.2, 1) 0.15s;
      }
      html.has-intro .hero-scroll {
        transition: opacity 0.9s cubic-bezier(0.4, 0, 0.2, 1) 0.7s;
      }
      /* Nav slides down from the top. "menu pops up across the top" */
      html.has-intro .nav {
        transform: translateY(-100%);
        transition:
          transform 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.05s,
          opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1) 0.05s;
      }
      html.has-intro.intro-done .nav {
        transform: translateY(0);
        opacity: 1;
      }
      html.has-intro.intro-done .hero-logo-top,
      html.has-intro.intro-done .hero-scroll,
      html.has-intro.intro-done .hero-tag,
      html.has-intro.intro-done .meta-pin,
      html.has-intro.intro-done .scroll-progress { opacity: 1; }
      /* Hero copy: each child rises + fades with stagger after intro-done */
      html.has-intro .hero-headline-wrap > * {
        opacity: 0;
        transform: translateY(36px);
        transition:
          opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
          transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
      }
      html.has-intro.intro-done .hero-headline-wrap > * {
        opacity: 1;
        transform: translateY(0);
      }
      html.has-intro.intro-done .hero-headline-wrap > *:nth-child(1) { transition-delay: 0.18s; }
      html.has-intro.intro-done .hero-headline-wrap > *:nth-child(2) { transition-delay: 0.34s; }
      html.has-intro.intro-done .hero-headline-wrap > *:nth-child(3) { transition-delay: 0.5s; }

      /* ---------- Scroll progress bar ---------- */
      .scroll-progress {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 2px;
        z-index: 100;
        background: rgba(255,255,255,0.06);
        pointer-events: none;
      }
      .scroll-progress span {
        display: block;
        height: 100%;
        width: 0%;
        background: var(--bone);
        transition: width 0.08s linear;
      }

      /* ---------- Nav (logo left, menu toggle right) ---------- */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 80;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px var(--gut);
        transition: background 0.4s var(--ease), padding 0.4s var(--ease);
        pointer-events: none;
      }
      .nav > * { pointer-events: auto; }
      .nav.scrolled {
        background: rgba(10, 10, 10, 0.78);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        padding: 14px var(--gut);
      }
      .nav-logo { display: inline-flex; align-items: center; }
      .nav-logo-img {
        height: 144px;
        width: auto;
        filter: brightness(0) invert(1);
        transition: height 0.4s var(--ease), opacity 0.3s var(--ease);
      }
      .nav.scrolled .nav-logo-img { height: 56px; }
      .nav-logo:hover .nav-logo-img { opacity: 0.75; }

      /* Inline primary nav links across the top. Build · Design · About · ... */
      .nav-links {
        display: flex;
        gap: clamp(18px, 1.8vw, 36px);
        align-items: center;
      }
      .nav-links a {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 400;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--bone);
        text-decoration: none;
        padding: 6px 0;
        position: relative;
        opacity: 0.85;
        transition: opacity 0.3s var(--ease);
      }
      .nav-links a::after {
        content: '';
        position: absolute;
        left: 0; right: 0; bottom: -2px;
        height: 1px;
        background: currentColor;
        transform: scaleX(0);
        transform-origin: center;
        opacity: 0.7;
        transition: transform 0.4s var(--ease);
      }
      .nav-links a:hover { opacity: 1; }
      .nav-links a:hover::after,
      .nav-links a.is-active::after { transform: scaleX(1); }
      .nav-links a.is-active { opacity: 1; }
      @media (max-width: 1100px) { .nav-links { display: none; } }
      @media (min-width: 1101px) { .nav-menu { display: none; } }

      .nav-menu {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        padding: 12px 22px;
        cursor: pointer;
        background: rgba(0, 0, 0, 0.22);
        border: 1px solid rgba(242, 237, 230, 0.30);
        border-radius: 999px;
        color: var(--bone);
        z-index: 90;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: background 0.3s var(--ease), border-color 0.3s var(--ease);
      }
      .nav-menu:hover {
        background: rgba(0, 0, 0, 0.38);
        border-color: rgba(242, 237, 230, 0.6);
      }
      .nav-menu-label {
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        transition: opacity 0.3s var(--ease);
      }
      .nav-menu:hover .nav-menu-label { opacity: 0.85; }
      .nav-menu-icon {
        display: inline-flex;
        flex-direction: column;
        gap: 7px;
        width: 30px;
      }
      .nav-menu-icon span {
        display: block;
        height: 1.5px;
        background: var(--bone);
        width: 100%;
        transition: transform 0.45s var(--ease), width 0.4s var(--ease), opacity 0.2s;
      }
      .nav-menu-icon span:nth-child(2) { width: 60%; align-self: flex-end; }
      .nav-menu:hover .nav-menu-icon span:nth-child(2) { width: 100%; }
      body.menu-open .nav-menu-icon span:nth-child(1) { transform: translateY(4.25px) rotate(45deg); width: 100%; }
      body.menu-open .nav-menu-icon span:nth-child(2) { transform: translateY(-4.25px) rotate(-45deg); width: 100%; }

      /* ---------- Meta pin (location + clock, bottom-left of viewport) ---------- */
      .meta-pin {
        position: fixed;
        bottom: 22px;
        left: var(--gut);
        z-index: 70;
        display: flex;
        gap: 16px;
        align-items: center;
        font-family: var(--sans);
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--grey-4);
        pointer-events: none;
        mix-blend-mode: difference;
        opacity: 0.7;
      }
      .meta-pin .dot {
        display: inline-block;
        width: 5px; height: 5px;
        border-radius: 50%;
        background: #7eaa7e;
        margin-right: 8px;
        vertical-align: middle;
        animation: pulse 2.4s ease-in-out infinite;
      }
      body.menu-open .meta-pin { opacity: 0; transition: opacity 0.3s; }

      .nav-overlay {
        position: fixed; inset: 0;
        background: var(--black);
        z-index: 85;
        transform: translateY(-100%);
        transition: transform 0.55s var(--ease);
        display: flex; flex-direction: column;
        justify-content: center;
        padding: 0 var(--gut);
      }
      body.menu-open .nav-overlay { transform: translateY(0); }
      .nav-overlay-links { display: flex; flex-direction: column; gap: 14px; }
      .nav-overlay-links a {
        font-family: var(--serif);
        font-size: clamp(40px, 9vw, 72px);
        color: var(--bone);
        line-height: 1;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s var(--ease), transform 0.5s var(--ease);
      }
      body.menu-open .nav-overlay-links a { opacity: 1; transform: translateY(0); }
      body.menu-open .nav-overlay-links a:nth-child(1) { transition-delay: 0.15s; }
      body.menu-open .nav-overlay-links a:nth-child(2) { transition-delay: 0.20s; }
      body.menu-open .nav-overlay-links a:nth-child(3) { transition-delay: 0.25s; }
      body.menu-open .nav-overlay-links a:nth-child(4) { transition-delay: 0.30s; }
      body.menu-open .nav-overlay-links a:nth-child(5) { transition-delay: 0.35s; }
      body.menu-open .nav-overlay-links a:nth-child(6) { transition-delay: 0.40s; }
      .nav-overlay-close {
        position: absolute;
        top: 28px;
        right: var(--gut);
        z-index: 90;
        display: inline-flex;
        align-items: center;
        gap: 14px;
        padding: 10px 4px;
        background: transparent;
        border: 0;
        cursor: pointer;
        color: var(--bone);
        font-family: var(--sans);
        font-size: 11px;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s var(--ease);
      }
      body.menu-open .nav-overlay-close { opacity: 1; pointer-events: auto; transition-delay: 0.25s; }
      .nav-overlay-close-label { opacity: 0.85; }
      .nav-overlay-close:hover .nav-overlay-close-label { opacity: 1; }
      .nav-overlay-close-icon {
        position: relative;
        width: 18px;
        height: 18px;
        display: inline-block;
      }
      .nav-overlay-close-icon span {
        position: absolute;
        left: 0; top: 50%;
        width: 100%;
        height: 1px;
        background: var(--bone);
        transition: background 0.2s var(--ease);
      }
      .nav-overlay-close-icon span:nth-child(1) { transform: rotate(45deg); }
      .nav-overlay-close-icon span:nth-child(2) { transform: rotate(-45deg); }
      @media (max-width: 760px) {
        .nav-overlay-close-label { display: none; }
      }

      .nav-overlay-meta {
        position: absolute;
        bottom: 32px; left: var(--gut); right: var(--gut);
        display: flex; justify-content: space-between;
        font-size: 11px; letter-spacing: 0.22em;
        text-transform: uppercase; color: var(--grey-4);
        border-top: 1px solid var(--rule); padding-top: 18px;
      }

      /* ---------- Footer ---------- */
      .footer {
        background: var(--black);
        color: var(--bone);
        padding: clamp(80px, 10vw, 140px) var(--gut) 36px;
        border-top: 1px solid var(--rule);
      }
      .footer-top {
        display: grid;
        grid-template-columns: 1.6fr 1fr 1fr 1fr 1.2fr;
        gap: clamp(24px, 3.5vw, 48px);
        padding-bottom: clamp(60px, 6vw, 96px);
        border-bottom: 1px solid var(--rule);
      }
      .footer-col-locations ul { columns: 1; }
      .footer-col-locations ul li { padding: 4px 0; font-size: 13px; color: var(--grey-3); }
      .footer-logo-img {
        width: clamp(160px, 16vw, 240px);
        height: auto;
        filter: brightness(0) invert(1);
      }
      .footer-col h5 {
        font-family: var(--sans);
        font-weight: 400;
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--grey-4);
        margin-bottom: 18px;
      }
      .footer-col ul li { padding: 6px 0; }
      .footer-col ul li a:hover { opacity: 0.6; }
      .footer-bottom {
        display: flex; justify-content: space-between; align-items: center;
        padding-top: 28px;
        font-size: 11px; letter-spacing: 0.22em;
        text-transform: uppercase; color: var(--grey-4);
      }
      .footer-bottom .socials { display: flex; gap: 20px; }

      @media (max-width: 1280px) {
        .footer-top { grid-template-columns: 1.4fr 1fr 1fr 1fr; }
        .footer-col-locations { grid-column: 1 / -1; }
        .footer-col-locations ul { columns: 3; column-gap: 28px; }
      }
      @media (max-width: 1024px) {
        .footer-top { grid-template-columns: 1fr 1fr; }
        .footer-col-locations ul { columns: 2; }
      }
      @media (max-width: 760px) {
        .footer-top { grid-template-columns: 1fr; }
        .nav-logo-img { height: 110px; }
        .nav.scrolled .nav-logo-img { height: 44px; }
        .meta-pin { font-size: 9px; bottom: 14px; gap: 12px; }
        .nav-menu-label { display: none; }
      }
    </style>

    <!-- Lenis: buttery smooth scroll -->
    <script is:inline src="https://unpkg.com/lenis@1.1.20/dist/lenis.min.js"></script>

    <script>
      // ---------- Intro animation (homepage only): black → logo + kicker → split-zoom → handoff ----------
      const root = document.documentElement;
      if (root.classList.contains('has-intro') && !root.classList.contains('intro-skip')) {
        // Phase 1: entrance — logo + kicker fade up out of the black
        requestAnimationFrame(() => root.classList.add('intro-loaded'));
        const HOLD_MS    = 1500;  /* read time before split-zoom kicks off */
        const ZOOM_MS    = 800;   /* split-zoom phase: words converge on logo */
        const HANDOFF_MS = 700;   /* logo grows + overlay fades */

        // Phase 2: split-zoom toward the logo
        setTimeout(() => root.classList.add('intro-finishing'), HOLD_MS);
        // Phase 3: logo pulse complete — grow + handoff to hero (overlay fades)
        setTimeout(() => root.classList.add('intro-done'),       HOLD_MS + ZOOM_MS);
        // Cleanup: enable scroll, allow input
        setTimeout(() => root.classList.add('intro-finished'),   HOLD_MS + ZOOM_MS + HANDOFF_MS);
      }

      // ---------- Smooth scroll (Lenis) ----------
      const Lenis = (window as any).Lenis;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let lenis: any = null;
      if (Lenis && !reduceMotion) {
        lenis = new Lenis({
          duration: 1.15,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 1.4,
          gestureOrientation: 'vertical'
        });
      }

      // ---------- Single rAF loop ----------
      const progressBar = document.querySelector('.scroll-progress span') as HTMLElement | null;
      const parallaxNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
      const fadeNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-fade]'));
      const clipNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-clip]'));
      const xNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-x]'));
      const heroBg = document.querySelector<HTMLElement>('.hero .hero-bg, .page-hero .hero-bg, .hero .hero-video');
      // Horizontal pin-strips: vertical scroll inside section translates the track horizontally
      const hStrips = Array.from(document.querySelectorAll<HTMLElement>('.h-strip')).map((el) => ({
        el,
        track: el.querySelector<HTMLElement>('.h-strip-track')!,
        bar: el.querySelector<HTMLElement>('.h-strip-progress span')
      })).filter(s => s.track);

      const tick = (time?: number) => {
        if (lenis) lenis.raf(time ?? performance.now());

        const scrollY = window.scrollY;
        const vh = window.innerHeight;
        const docH = document.documentElement.scrollHeight - vh;

        if (progressBar) {
          const p = docH > 0 ? Math.min(1, Math.max(0, scrollY / docH)) : 0;
          progressBar.style.width = (p * 100) + '%';
        }

        if (heroBg && scrollY < vh) {
          heroBg.style.transform = `translate3d(0, ${scrollY * 0.25}px, 0) scale(1.06)`;
        }

        for (const el of parallaxNodes) {
          const r = el.getBoundingClientRect();
          const center = r.top + r.height / 2;
          const offset = (center - vh / 2);
          const ratio = parseFloat(el.dataset.parallax || '0.15');
          el.style.transform = `translate3d(0, ${(-offset * ratio).toFixed(2)}px, 0)`;
        }

        for (const el of fadeNodes) {
          const r = el.getBoundingClientRect();
          const p = 1 - Math.min(1, Math.max(0, (r.top - vh * 0.2) / (vh * 0.6)));
          el.style.opacity = p.toFixed(3);
        }

        for (const el of clipNodes) {
          const r = el.getBoundingClientRect();
          const p = 1 - Math.min(1, Math.max(0, (r.top - vh * 0.1) / (vh * 0.7)));
          const inset = ((1 - p) * 50).toFixed(1);
          el.style.clipPath = `inset(${inset}% 0 ${inset}% 0)`;
        }

        for (const el of xNodes) {
          const r = el.getBoundingClientRect();
          const p = 1 - Math.min(1, Math.max(0, (r.top - vh * 0.1) / (vh * 0.9)));
          const dist = parseFloat(el.dataset.x || '-160');
          el.style.transform = `translate3d(${(dist * (1 - p)).toFixed(1)}px, 0, 0)`;
        }

        // Horizontal pin-strips
        for (const s of hStrips) {
          const r = s.el.getBoundingClientRect();
          const total = s.el.offsetHeight - vh;
          const scrolled = Math.max(0, Math.min(total, -r.top));
          const p = total > 0 ? scrolled / total : 0;
          const trackW = s.track.scrollWidth;
          const dx = Math.max(0, trackW - window.innerWidth);
          s.track.style.transform = `translate3d(${(-dx * p).toFixed(1)}px, 0, 0)`;
          if (s.bar) s.bar.style.width = (p * 100).toFixed(2) + '%';
        }

        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      // ---------- Live clock ----------
      const updateClock = () => {
        const el = document.getElementById('navClock');
        if (!el) return;
        const time = new Date().toLocaleTimeString('en-US', {
          timeZone: 'America/Toronto',
          hour: '2-digit',
          minute: '2-digit',
          hour12: false
        });
        el.textContent = `${time} EST`;
      };
      updateClock();
      setInterval(updateClock, 1000);

      // ---------- Scrolled nav state ----------
      const nav = document.querySelector('.nav');
      const onScroll = () => {
        if (!nav) return;
        if (window.scrollY > 40) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // ---------- Menu toggle (one button, all viewports) ----------
      const menuBtn = document.querySelector('.nav-menu');
      menuBtn?.addEventListener('click', () => document.body.classList.toggle('menu-open'));
      const menuCloseBtn = document.querySelector('.nav-overlay-close');
      menuCloseBtn?.addEventListener('click', () => document.body.classList.remove('menu-open'));
      document.querySelectorAll('.nav-overlay-links a').forEach((a) => {
        a.addEventListener('click', () => document.body.classList.remove('menu-open'));
      });
      // Esc closes the overlay
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') document.body.classList.remove('menu-open');
      });

      // ---------- Scrollytelling: scoped per .scrolly section so multiple coexist ----------
      document.querySelectorAll<HTMLElement>('.scrolly').forEach((scrolly) => {
        const images = scrolly.querySelectorAll<HTMLElement>('.scrolly-image');
        const panels = scrolly.querySelectorAll<HTMLElement>('.scrolly-panel');
        const marks = scrolly.querySelectorAll<HTMLElement>('.scrolly-progress span');
        if (!images.length || !panels.length) return;
        const swap = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const i = (entry.target as HTMLElement).dataset.i;
                images.forEach((img) => img.classList.toggle('active', img.dataset.i === i));
                marks.forEach((m) => m.classList.toggle('is-active', m.dataset.i === i));
              }
            });
          },
          { threshold: 0.55, rootMargin: '-25% 0px -25% 0px' }
        );
        panels.forEach((p) => swap.observe(p));
      });

      // ---------- Reveal-on-enter ----------
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
      );
      document
        .querySelectorAll(
          '.reveal, .reveal-stagger, .fade-up, .fade-down, .fade-left, .fade-right, .scale-in, .clip-up'
        )
        .forEach((el) => observer.observe(el));

      // ---------- Split-text headlines ----------
      document.querySelectorAll<HTMLElement>('.split-text').forEach((el) => {
        const text = el.textContent || '';
        const words = text.split(/\s+/).filter(Boolean);
        el.innerHTML = words
          .map((w) => `<span class="word"><span class="inner">${w}</span></span>`)
          .join(' ');
      });
      const splitObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              splitObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.split-text').forEach((el) => splitObserver.observe(el));

      // ---------- Reel marquee (duplicate items for seamless loop) ----------
      const reel = document.querySelector('.reel-track');
      if (reel) reel.innerHTML += reel.innerHTML;

      // ---------- Contact form ----------
      const form = document.getElementById('contactForm');
      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const status = document.getElementById('formStatus');
          if (status) {
            status.textContent = 'Thank you. We will be in touch within two business days.';
            status.style.color = '#7eaa7e';
          }
          (form as HTMLFormElement).reset();
        });
      }
    </script>
  </body>
</html>
